{
  "name": "@superliora/monorepo",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/fix-node-pty-perms.mjs",
    "build": "corepack pnpm -r run build",
    "build:packages": "corepack pnpm -r --filter './packages/*' run build",
    "dev:cli": "corepack pnpm -C apps/liora run dev",
    "dev:cli:marketplace": "SUPERLIORA_DEV_MARKETPLACE_URL=https://raw.githubusercontent.com/claudianus/superliora/main/plugins/marketplace.json corepack pnpm -C apps/liora run dev",
    "install:liora": "node scripts/install-liora.mjs",
    "check:imports": "node scripts/check-workspace-imports.mjs",
    "check:source-install": "node scripts/check-source-install.mjs",
    "check:slop": "node scripts/check-ai-slop.mjs",
    "dev:server": "corepack pnpm -C apps/liora run dev:server",
    "build:plugin-marketplace": "corepack pnpm -C apps/liora run build:plugin-marketplace",
    "build:expert-catalog": "node scripts/build-expert-catalog.mjs",
    "build:skill-catalog": "node scripts/build-skill-catalog.mjs",
    "vis": "corepack pnpm -C apps/vis run dev",
    "dev:docs": "corepack pnpm -C apps/site run dev",
    "typecheck": "corepack pnpm run build:packages && corepack pnpm -r --filter './packages/*' run typecheck && corepack pnpm --filter @superliora/liora run typecheck && corepack pnpm --filter @superliora/vis-server run typecheck && corepack pnpm --filter @superliora/vis-web run typecheck",
    "lint": "oxlint --type-aware",
    "lint:fix": "corepack pnpm run lint --fix",
    "sherif": "sherif",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "corepack pnpm -r run clean",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "7.58.7",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "4.1.4",
    "lint-staged": "16.4.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "sherif": "1.11.1",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.22.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  },
  "simple-git-hooks": {
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "oxlint --fix --quiet",
      "oxlint --type-aware --quiet"
    ]
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "packageManager": "pnpm@10.33.0"
}
