{
  "name": "@superliora/protocol",
  "version": "0.3.0",
  "private": true,
  "description": "Shared REST + WS protocol schemas (envelope, error codes, pagination, ws-control) for the SuperLiora server.",
  "license": "MIT",
  "author": "SuperLiora Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claudianus/superliora.git",
    "directory": "packages/protocol"
  },
  "bugs": {
    "url": "https://github.com/claudianus/superliora/issues"
  },
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ulid": "^3.0.1",
    "zod": "^4.3.6"
  }
}
