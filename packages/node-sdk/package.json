{
  "name": "@superliora/sdk",
  "version": "0.10.1",
  "private": true,
  "description": "TypeScript SDK for the SuperLiora Agent",
  "license": "MIT",
  "author": "SuperLiora Contributors",
  "homepage": "https://github.com/claudianus/superliora/tree/main/packages/node-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claudianus/superliora.git",
    "directory": "packages/node-sdk"
  },
  "bugs": {
    "url": "https://github.com/claudianus/superliora/issues"
  },
  "keywords": [
    "superliora",
    "sdk",
    "typescript",
    "agent",
    "api"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      }
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsdown && corepack pnpm run build:dts",
    "build:dts": "node scripts/build-dts.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .tmp-api-extractor"
  },
  "dependencies": {
    "@antfu/utils": "^9.3.0",
    "smol-toml": "^1.6.1",
    "yazl": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@superliora/agent-core": "workspace:^",
    "@superliora/gui-use": "workspace:^",
    "@superliora/kaos": "workspace:^",
    "@superliora/kosong": "workspace:^",
    "@superliora/oauth": "workspace:^",
    "@types/yazl": "^2.4.6"
  }
}
