{
  "schemaVersion": 1,
  "id": "seed.secret-redaction-guard.v1",
  "title": "Quarantine secret-looking fixture",
  "suite": "guard",
  "kind": "guard",
  "risk": "low",
  "expectedOutcome": "QUARANTINED",
  "tags": [
    "secrets",
    "redaction",
    "zdr",
    "anti-overfit"
  ],
  "prompt": "This task intentionally contains a secret-looking fixture and must be quarantined before solver execution.",
  "budgets": {
    "maxWallMs": 30000,
    "maxCommands": 0,
    "maxPromptChars": 500
  },
  "setup": {
    "files": [
      {
        "path": ".env.leaked",
        "content": "OPENAI_API_KEY=sk-leaked-example-key-do-not-use\n"
      }
    ]
  },
  "fixtureActions": [
    {
      "type": "writeFile",
      "path": "should-not-run.txt",
      "content": "solver should not run\n"
    }
  ],
  "contamination": {
    "blockedFiles": [
      ".env.leaked"
    ]
  },
  "checks": [
    {
      "type": "file_exists",
      "path": "should-not-run.txt",
      "weight": 1
    }
  ]
}
