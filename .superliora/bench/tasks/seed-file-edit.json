{
  "schemaVersion": 1,
  "id": "seed.file-edit.v1",
  "title": "Create a checked config file",
  "suite": "seed",
  "kind": "file-edit",
  "risk": "low",
  "tags": ["coding", "filesystem", "deterministic-check"],
  "prompt": "Create src/config.json with mode set to bench, enabled set to true, and a notes array containing ultrawork.",
  "budgets": {
    "maxWallMs": 120000,
    "maxCommands": 8,
    "maxPromptChars": 1200
  },
  "setup": {
    "files": [
      {
        "path": "README.md",
        "content": "# Bench fixture\n\nThis disposable workspace is owned by Super SuperLiora Agent Bench.\n"
      }
    ]
  },
  "fixtureActions": [
    {
      "type": "writeFile",
      "path": "src/config.json",
      "content": "{\n  \"mode\": \"bench\",\n  \"enabled\": true,\n  \"notes\": [\"ultrawork\"]\n}\n"
    }
  ],
  "contamination": {
    "blockedFiles": ["answers/solution.txt", ".superliora/evidence/stale-pass.json"]
  },
  "checks": [
    {
      "type": "file_exists",
      "path": "src/config.json",
      "weight": 1
    },
    {
      "type": "json_field",
      "path": "src/config.json",
      "pointer": "/mode",
      "equals": "bench",
      "weight": 1
    },
    {
      "type": "json_field",
      "path": "src/config.json",
      "pointer": "/enabled",
      "equals": true,
      "weight": 1
    },
    {
      "type": "file_contains",
      "path": "src/config.json",
      "text": "ultrawork",
      "weight": 1
    }
  ]
}
